{
  "path_skip_globs": [
    "__tests__/*",
    "*/__tests__/*",
    "*.test.*",
    "*.spec.*",
    "tests/*",
    "*/tests/*",
    "fixtures/*",
    "*/fixtures/*",
    "*.example*",
    "*.sample*",
    "docs/*",
    "*/docs/*",
    "*.md",
    "README*",
    "node_modules/*",
    "*/node_modules/*",
    "vendor/*",
    "*/vendor/*",
    ".git/*",
    "*/.git/*",
    "dist/*",
    "*/dist/*",
    ".next/*",
    "*/.next/*",
    "build/*",
    "*/build/*"
  ],
  "secret_placeholder_values": [
    "changeme",
    "change-me",
    "your-key-here",
    "your-api-key",
    "replace-me",
    "xxx",
    "xxxxxxxx",
    "example",
    "placeholder",
    "<api-key>",
    "<your-key>",
    "test-key",
    "fake-key"
  ],
  "public_route_name_allowlist": [
    "/api/health",
    "/api/healthz",
    "/api/og",
    "/api/webhook",
    "/api/webhooks",
    "/api/cron"
  ],
  "webhook_signature_signals": [
    "constructEvent",
    "verifySignature",
    "verify_signature",
    "X-Hub-Signature",
    "X-Signature",
    "hmac"
  ],
  "auth_positive_signals": [
    "getServerSession",
    "auth()",
    "requireUser",
    "currentUser(",
    "verifyIdToken",
    "passport.authenticate",
    "req.session.user",
    "req.user",
    "jwt.verify",
    "requireAuth",
    "isAuthenticated",
    "withAuth",
    "login_required",
    "LoginRequiredMixin",
    "permission_classes",
    "flask_login"
  ]
}
